# Escala (Next.js) - Example Environment Variables
# Copy this file to `.env` and fill in the values as needed.

# Runtime
# One of: development | production | test
NODE_ENV=development

# URL do site institucional (Landing Pages)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public URL where the Next.js app is reachable. Used for SEO metadata and social previews.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only Spring Boot API base URL. Use http://backend:8080 in Docker Compose.
API_BASE_URL=http://localhost:8080

NEXT_PUBLIC_COMPANY_SLUG=escala-demo

# URL Pública do CMS
STRAPI_PUBLIC_URL=http://localhost:1337

# Internal Strapi base URL used by the app (same as above for local dev).
# Use localhost when running `pnpm dev` on the host.
# Docker Compose overrides this to http://strapi:1337.
NEXT_INTERNAL_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_API=http://localhost:1337

# Public URL for Strapi assets (images/files). Often same as Strapi base URL.
# Example: http://localhost:1337 or https://cms.example.com
NEXT_PUBLIC_STRAPI_PUBLIC_URL=http://localhost:1337

# Configurações de Campanha e Marketing
CAMPAIGN_COOKIE_NAME=escala_marketing_attribution
MARKETING_ATTRIBUTION_TTL_DAYS=30

# NextAuth configuration
# Public URL where the Next.js app is reachable. Example: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Secret for NextAuth (generate with: `openssl rand -base64 32`)
NEXTAUTH_SECRET=changeme

# Google OAuth. Backend validates the Google id_token with GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# reCAPTCHA is enforced only by the Spring Boot production profile.
RECAPTCHA_SECRET=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Defaults to false in development and true in production.
NEXT_PUBLIC_RECAPTCHA_ENABLED=false
