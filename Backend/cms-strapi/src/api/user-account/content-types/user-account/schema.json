{
  "kind": "collectionType",
  "collectionName": "user-accounts",
  "info": {
    "singularName": "user-account",
    "pluralName": "user-accounts",
    "displayName": "User Account"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "username": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "password": {
      "type": "password",
      "required": true
    },
    "theme": {
      "type": "enumeration",
      "default": "system",
      "enum": [
        "light",
        "dark",
        "system"
      ]
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "last_login": {
      "type": "datetime"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "address": {
      "type": "string"
    },
    "position": {
      "type": "string"
    },
    "function": {
      "type": "string"
    },
    "cep": {
      "type": "string"
    },
    "street": {
      "type": "string"
    },
    "number": {
      "type": "string"
    },
    "complement": {
      "type": "string"
    },
    "neighborhood": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    }
  }
}
