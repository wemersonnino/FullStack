{
  "kind": "collectionType",
  "collectionName": "landing_pages",
  "info": {
    "singularName": "landing-page",
    "pluralName": "landing-pages",
    "displayName": "Landing Page",
    "description": "Conteudo editorial da home/landing publica do produto."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "pageKey": {
      "type": "enumeration",
      "enum": [
        "home",
        "segment",
        "campaign",
        "generic"
      ],
      "default": "generic",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "heroTitle",
      "required": false
    },
    "eyebrow": {
      "type": "string"
    },
    "heroTitle": {
      "type": "string",
      "required": true
    },
    "heroDescription": {
      "type": "text",
      "required": true
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "heroBackgroundImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "sectionBackgroundImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "primaryCtaLabel": {
      "type": "string",
      "default": "Comecar teste gratis"
    },
    "primaryCtaUrl": {
      "type": "string",
      "default": "/register"
    },
    "secondaryCtaLabel": {
      "type": "string",
      "default": "Solicitar demonstracao"
    },
    "secondaryCtaUrl": {
      "type": "string",
      "default": "#contato"
    },
    "trialDescription": {
      "type": "string",
      "default": "3 meses de teste gratuito da aplicacao."
    },
    "aiTrialDescription": {
      "type": "string",
      "default": "IA assistiva com periodo menor ou limite de creditos para controle de custo."
    },
    "securityStatement": {
      "type": "text"
    },
    "demoEyebrow": {
      "type": "string",
      "default": "Demo"
    },
    "demoTitle": {
      "type": "string",
      "default": "Veja a operacao antes de conversar com vendas."
    },
    "demoDescription": {
      "type": "text",
      "default": "A demonstracao mostra como a plataforma organiza escalas, aponta limites comerciais e captura leads com consentimento explicito."
    },
    "demoCards": {
      "type": "json"
    },
    "demoLinkLabel": {
      "type": "string",
      "default": "Abrir pagina de demo"
    },
    "demoLinkUrl": {
      "type": "string",
      "default": "/demo"
    },
    "demoFormTitle": {
      "type": "string",
      "default": "Receba uma proposta guiada"
    },
    "demoFormDescription": {
      "type": "text",
      "default": "Deixe seu contato e a gente responde com uma demonstracao focada na sua operacao."
    },
    "featuresEyebrow": {
      "type": "string",
      "default": "Modulos"
    },
    "featuresTitle": {
      "type": "string",
      "default": "Operacao, regras e auditoria no mesmo fluxo."
    },
    "industriesEyebrow": {
      "type": "string",
      "default": "Setores"
    },
    "industriesTitle": {
      "type": "string",
      "default": "Preparado para operacoes com ritmos diferentes."
    },
    "pricingEyebrow": {
      "type": "string",
      "default": "Planos"
    },
    "pricingTitle": {
      "type": "string",
      "default": "Teste comercial com controle de custo da IA."
    },
    "faqEyebrow": {
      "type": "string",
      "default": "FAQ"
    },
    "faqTitle": {
      "type": "string",
      "default": "Perguntas frequentes."
    },
    "blogEyebrow": {
      "type": "string",
      "default": "Conteudo"
    },
    "blogTitle": {
      "type": "string",
      "default": "Conteudo para gestores."
    },
    "blogDescription": {
      "type": "text",
      "default": "Artigos editoriais continuam vindo do Strapi."
    },
    "blogLinkLabel": {
      "type": "string",
      "default": "Ver artigos"
    },
    "blogLinkUrl": {
      "type": "string",
      "default": "/artigos"
    },
    "features": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::feature-section.feature-section"
    },
    "industries": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::industry-section.industry-section"
    },
    "segment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::market-segment.market-segment"
    },
    "pricingPlans": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::pricing-plan-content.pricing-plan-content"
    },
    "faqs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq.faq"
    },
    "ctaButtons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::cta-button.cta-button"
    },
    "vslTitle": {
      "type": "string"
    },
    "vslVideoUrl": {
      "type": "string"
    },
    "vslScript": {
      "type": "text"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
